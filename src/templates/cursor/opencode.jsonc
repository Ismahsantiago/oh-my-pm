{
  // Oh My PM project-level OpenCode configuration for Cursor.
  // Cursor ships with OpenCode built-in — this registers the PM agent team.
  // Model presets are configured in oh-my-pm.json — edit that file to switch providers.
  // The runtime plugin (oh-my-pm@latest) injects agent prompts, tools, and models.
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-pm@latest"
  ]
}
